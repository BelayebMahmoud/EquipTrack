            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(r).to.be.an('array'));",
                  "pm.test('Each employee has required fields', () => {",
                  "  if (r.length > 0) {",
                  "    pm.expect(r[0]).to.have.all.keys('id', 'firstName', 'lastName', 'email', 'department');",
                  "  }",
                  "});"
